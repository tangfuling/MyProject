# Server
SERVER_PORT=8081
SPRING_PROFILES_ACTIVE=dev

# MySQL
MYSQL_URL=jdbc:mysql://127.0.0.1:3306/gzh?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false
MYSQL_USERNAME=root
MYSQL_PASSWORD=root

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=please-change-me-to-32-bytes-at-least
JWT_EXPIRE_DAYS=30

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,chrome-extension://*

# SMS provider (HTTP endpoint)
SMS_ENDPOINT=https://your-sms-provider.example.com/send
SMS_API_KEY=
SMS_API_SECRET=
SMS_SIGN_NAME=公众号助手
SMS_TEMPLATE_CODE=SMS_000000001

# AI model selection
AI_DEFAULT_MODEL=qwen
AI_TIMEOUT_MS=30000

# Qwen
QWEN_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
QWEN_API_KEY=
QWEN_MODEL=qwen-plus

# Doubao
DOUBAO_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/chat/completions
DOUBAO_API_KEY=
DOUBAO_MODEL=doubao-seed-1-6-thinking-250715

# GPT
GPT_ENDPOINT=https://api.openai.com/v1/chat/completions
GPT_API_KEY=
GPT_MODEL=gpt-4o-mini

# Claude
CLAUDE_ENDPOINT=https://api.anthropic.com/v1/messages
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-latest

# Alipay
ALIPAY_GATEWAY_URL=https://openapi.alipay.com/gateway.do
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=https://api-gzh.niuma.com/payment/notify
ALIPAY_RETURN_URL=https://gzh.niuma.com/settings
