{
  "manifest_version": 3,
  "name": "公众号助手",
  "version": "1.0.0",
  "description": "同步微信公众号后台数据到公众号助手",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://mp.weixin.qq.com/*",
    "http://localhost:5173/*",
    "https://gzh.niuma.com/*",
    "https://gzh.niumatech.com/*",
    "http://127.0.0.1:8081/*",
    "https://api-gzh.niumatech.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://mp.weixin.qq.com/*"],
      "js": ["http-config.js", "content-script.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost:5173/*",
        "https://gzh.niuma.com/*",
        "https://gzh.niumatech.com/*"
      ],
      "js": ["http-config.js", "web-auth-sync.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*.png"],
      "matches": ["https://mp.weixin.qq.com/*"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  }
}
